{
  "name": "very-happy-dom",
  "type": "module",
  "version": "0.1.3",
  "description": "Like a light-weight version of `happy-dom` powered by Bun.",
  "author": "Chris Breuer <chris@stacksjs.org>",
  "license": "MIT",
  "homepage": "https://github.com/stacksjs/very-happy-dom#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stacksjs/very-happy-dom.git"
  },
  "bugs": {
    "url": "https://github.com/stacksjs/very-happy-dom/issues"
  },
  "keywords": [
    "very-happy-dom",
    "happy-dom",
    "dom",
    "testing",
    "bun",
    "jsdom",
    "virtual-dom"
  ],
  "sideEffects": [
    "./src/index.ts",
    "./dist/index.js",
    "./dist/index.d.ts"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "bun": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./register": {
      "types": "./dist/register.d.ts",
      "bun": "./src/register.ts",
      "import": "./dist/register.js"
    },
    "./jsdom": {
      "types": "./dist/jsdom/index.d.ts",
      "bun": "./src/jsdom/index.ts",
      "import": "./dist/jsdom/index.js"
    },
    "./*": {
      "import": "./dist/*"
    }
  },
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "README.md",
    "dist",
    "src"
  ],
  "scripts": {
    "build": "bun --bun build.ts",
    "fresh": "bunx rimraf node_modules/ bun.lock && bun i",
    "prepublishOnly": "bun --bun run build",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "bench": "bun run benchmark/index.ts",
    "bench:json": "bun run benchmark/index.ts -- --format json",
    "bench:quiet": "bun run benchmark/index.ts -- --format quiet",
    "lint": "bunx --bun pickier .",
    "lint:fix": "bunx --bun pickier . --fix",
    "format": "bunx --bun pickier . --format",
    "format:fix": "bunx --bun pickier . --format --write",
    "changelog": "bunx --bun logsmith --verbose",
    "changelog:generate": "bunx --bun logsmith --output CHANGELOG.md",
    "release": "bun run changelog:generate && bunx --bun bumpx prompt --recursive",
    "postinstall": "bunx --bun git-hooks",
    "typecheck": "bun --bun tsc --noEmit"
  },
  "devDependencies": {
    "@stacksjs/bunpress": "^0.1.4",
    "better-dx": "^0.2.7",
    "bunfig": "^0.15.6",
    "mitata": "^1.0.34"
  },
  "git-hooks": {
    "pre-commit": {
      "staged-lint": {
        "*.{js,ts,json,yaml,yml,md}": "bunx --bun pickier lint --fix"
      }
    },
    "commit-msg": "bunx gitlint --edit .git/COMMIT_EDITMSG"
  }
}
